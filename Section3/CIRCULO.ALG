Algoritmo "Circulo"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Descriçăo   : Fazer um programa para calcular o valor da area de um circulo.
// Autor(a)    : Walter
// Data atual  : 21/02/2026
Var

   raio , area : real

Inicio

  escreva ("Digite o valor da raio do circulo: ")
  leia (raio)
  area <- pi * raio^2
  
  escreva ("Area= ", area:6:3)

Fimalgoritmo